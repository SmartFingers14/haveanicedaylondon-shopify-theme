<section style="padding:80px 24px"><div class="container" style="max-width:480px"><h2 class="h2">Reset password</h2>{% form 'reset_customer_password' %}<input type="password" name="customer[password]" required placeholder="New password" style="width:100%;padding:14px 18px;border:2px solid var(--ink);border-radius:14px;margin-top:18px"><input type="password" name="customer[password_confirmation]" required placeholder="Confirm" style="width:100%;padding:14px 18px;border:2px solid var(--ink);border-radius:14px;margin-top:10px"><button class="btn btn-primary" style="margin-top:18px;width:100%">Reset</button>{{ form.errors | default_errors }}{% endform %}</div></section>
