<section style="padding:80px 24px;min-height:60vh">
  <div class="container" style="max-width:480px">
    <h2 class="h2" style="text-align:center">Create <em>account</em></h2>
    {% form 'create_customer' %}
      <input type="text" name="customer[first_name]" placeholder="First name" style="width:100%;padding:14px 18px;border:2px solid var(--ink);border-radius:14px;margin-top:18px">
      <input type="text" name="customer[last_name]" placeholder="Last name" style="width:100%;padding:14px 18px;border:2px solid var(--ink);border-radius:14px;margin-top:10px">
      <input type="email" name="customer[email]" required placeholder="Email" style="width:100%;padding:14px 18px;border:2px solid var(--ink);border-radius:14px;margin-top:10px">
      <input type="password" name="customer[password]" required placeholder="Password" style="width:100%;padding:14px 18px;border:2px solid var(--ink);border-radius:14px;margin-top:10px">
      <button type="submit" class="btn btn-primary" style="margin-top:18px;width:100%">Create â†’</button>
      {{ form.errors | default_errors }}
    {% endform %}
  </div>
</section>
