        "story": {
            "type": "v3-story",
            "settings": {
                "eyebrow": "Camden / 1990 → Now",
                "h2_line1": "Born In",
                "h2_pink": "Camden.",
                "h2_line2": "Raised By",
                "h2_yellow": "Rave.",
                "h2_line3": "Back For Real.",
                "body1": "Have A Nice Day started in 1990, in the back rooms of Camden's underground rave scene. The flyers, the flags, the dancefloors — and one hand-drawn character, Sam The Man, who became the face of a movement.",
                "body2": "After 17 years off the shelves, the original archive is back — not as nostalgia, as continuation. Same characters. Same family of cult sub-brands. Now printed on heavyweight organic cotton, in the UK, by the people who started it.",
                "cta_label": "Read The Full Story →",
                "stamp_left_label": "Character — 001",
                "stamp_left_value": "Sam The Man",
                "stamp_right_label": "Est. 1990",
                "stamp_right_value": "Camden NW1"
            }
        },
