        "heritage": {
            "type": "home-heritage",
            "settings": {
                "scribble": "back, baby",
                "big_top": "17 Years.",
                "big_mid": "Now Back.",
                "big_bot": "",
                "eyebrow": "Today's Story",
                "heading": "Born in a Camden corridor. Adopted by ravers.",
                "body": "We started at the back of American Rag Store, Camden Market - a corridor smelling of incense and 12-inch records. The smiley was a sticker before it was a t-shirt. The t-shirt became a culture. After 17 years away, the architects are bringing it back - same studio, same ethos, organic cotton this time.",
                "signed": "- The Architects"
            },
            "blocks": {
                "s1": {
                    "type": "stat",
                    "settings": {
                        "num": "1990",
                        "label": "Camden Origin"
                    }
                },
