{% comment %}
  Brand Page: Vortex — Info The Robot · Close Encounter · Cosmic Streetwear
  Deep space, psychedelic, cosmic — dark universe, electric purple/cyan, orbital energy
{% endcomment %}

{%- assign vortex_col = collections['vortex'] -%}

<!-- ============================================================
     HERO — Full viewport, cosmic space aesthetic
     ============================================================ -->
<section class="vx-hero">

  <!-- Animated starfield -->
  <div class="vx-stars" aria-hidden="true">
    <div class="vx-stars-layer vx-s1"></div>
    <div class="vx-stars-layer vx-s2"></div>
    <div class="vx-stars-layer vx-s3"></div>
  </div>

  <!-- Orbital rings -->
  <div class="vx-orbit vx-orbit1" aria-hidden="true"></div>
  <div class="vx-orbit vx-orbit2" aria-hidden="true"></div>
  <div class="vx-orbit vx-orbit3" aria-hidden="true"></div>

  <!-- Vortex spiral core -->
  <div class="vx-core" aria-hidden="true">
    <div class="vx-core-ring vx-cr1"></div>
    <div class="vx-core-ring vx-cr2"></div>
    <div class="vx-core-ring vx-cr3"></div>
    <div class="vx-core-dot"></div>
  </div>

  <div class="vx-hero-content">
    <div class="vx-eyebrow">
      <span class="vx-signal"></span>
      Camden · Est. 1993
      <span class="vx-signal"></span>
    </div>
    <h1 class="vx-hero-h1">
      <span class="vx-word vx-w1">VORTEX</span>
    </h1>
    <p class="vx-hero-sub">Info The Robot. Close Encounter. Stargate. Trapped.<br>Cosmic streetwear from another dimension.</p>
    <div class="vx-hero-cta">
      <a class="vx-btn-primary" href="#vx-shop">Enter The Vortex &#8594;</a>
      <a class="vx-btn-ghost" href="/collections/vortex">Full Collection</a>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="vx-scroll-hint" aria-hidden="true">
    <span class="vx-scroll-line"></span>
    <span class="vx-scroll-text">SCROLL</span>
  </div>

</section>

<!-- ============================================================
     SIGNAL STRIP — Scrolling brand tags
     ============================================================ -->
<div class="vx-signal-strip" aria-hidden="true">
  <div class="vx-signal-track">
    <span>VORTEX</span><span>&#9679;</span>
    <span>INFO THE ROBOT</span><span>&#9679;</span>
    <span>CLOSE ENCOUNTER</span><span>&#9679;</span>
    <span>STARGATE</span><span>&#9679;</span>
    <span>TRAPPED</span><span>&#9679;</span>
    <span>ENERGIZE</span><span>&#9679;</span>
    <span>ALIENNE</span><span>&#9679;</span>
    <span>TRUCKING</span><span>&#9679;</span>
    <span>VORTEX</span><span>&#9679;</span>
    <span>INFO THE ROBOT</span><span>&#9679;</span>
    <span>CLOSE ENCOUNTER</span><span>&#9679;</span>
    <span>STARGATE</span><span>&#9679;</span>
    <span>TRAPPED</span><span>&#9679;</span>
    <span>ENERGIZE</span><span>&#9679;</span>
    <span>ALIENNE</span><span>&#9679;</span>
    <span>TRUCKING</span><span>&#9679;</span>
  </div>
</div>

<!-- ============================================================
     STORY — Brand narrative
     ============================================================ -->
<section class="vx-story-section">
  <div class="vx-story-inner">

    <div class="vx-story-visual" aria-hidden="true">
      <div class="vx-planet vx-p1"></div>
      <div class="vx-planet vx-p2"></div>
      <div class="vx-planet vx-p3"></div>
      <div class="vx-nebula"></div>
    </div>

    <div class="vx-story-text">
      <div class="vx-story-label">// TRANSMISSION RECEIVED</div>
      <h2 class="vx-story-h2">Born from the<br><em>Camden underground.</em></h2>
      <p>Vortex is the cosmic arm of Have A Nice Day — a brand that looks beyond the street and into the stars. Psychedelic prints, sci-fi characters, and otherworldly graphics that blur the line between streetwear and space travel.</p>
      <p>From Info The Robot to Close Encounter, every design is a portal. Wear it and enter the vortex.</p>
      <div class="vx-story-stats">
        <div class="vx-stat">
          <div class="vx-stat-num">30+</div>
          <div class="vx-stat-label">Years in Camden</div>
        </div>
        <div class="vx-stat">
          <div class="vx-stat-num">46</div>
          <div class="vx-stat-label">Cosmic Pieces</div>
        </div>
        <div class="vx-stat">
          <div class="vx-stat-num">∞</div>
          <div class="vx-stat-label">Dimensions</div>
        </div>
      </div>
    </div>

  </div>
</section>

<!-- ============================================================
     COLLECTIONS — Design series grid
     ============================================================ -->
<section class="vx-series-section">
  <div class="vx-series-inner">
    <div class="vx-section-head">
      <div class="vx-section-label">// DESIGN SERIES</div>
      <h2 class="vx-section-h2">Explore the<br><em>Universes</em></h2>
    </div>
    <div class="vx-series-grid">
      <a class="vx-series-card vx-sc-robot" href="/collections/vortex">
        <div class="vx-sc-glow"></div>
        <div class="vx-sc-content">
          <div class="vx-sc-icon">&#129302;</div>
          <div class="vx-sc-name">Info The Robot</div>
          <div class="vx-sc-desc">Grey Edition · T-Shirts · Hoodies · Longsleeves</div>
          <div class="vx-sc-arrow">&#8599;</div>
        </div>
      </a>
      <a class="vx-series-card vx-sc-encounter" href="/collections/vortex">
        <div class="vx-sc-glow"></div>
        <div class="vx-sc-content">
          <div class="vx-sc-icon">&#128125;</div>
          <div class="vx-sc-name">Close Encounter</div>
          <div class="vx-sc-desc">Front &amp; Back Print · Organic · Full Range</div>
          <div class="vx-sc-arrow">&#8599;</div>
        </div>
      </a>
      <a class="vx-series-card vx-sc-stargate" href="/collections/vortex">
        <div class="vx-sc-glow"></div>
        <div class="vx-sc-content">
          <div class="vx-sc-icon">&#11088;</div>
          <div class="vx-sc-name">Stargate</div>
          <div class="vx-sc-desc">Organic · Front &amp; Back · Portal Prints</div>
          <div class="vx-sc-arrow">&#8599;</div>
        </div>
      </a>
      <a class="vx-series-card vx-sc-energize" href="/collections/vortex">
        <div class="vx-sc-glow"></div>
        <div class="vx-sc-content">
          <div class="vx-sc-icon">&#9889;</div>
          <div class="vx-sc-name">Energize</div>
          <div class="vx-sc-desc">T-Shirts · Hoodies · Longsleeves · Sweatshirts</div>
          <div class="vx-sc-arrow">&#8599;</div>
        </div>
      </a>
    </div>
  </div>
</section>

<!-- ============================================================
     SHOP — Product grid
     ============================================================ -->
<section class="vx-shop-section" id="vx-shop">
  <div class="vx-shop-inner">

    <div class="vx-section-head">
      <div class="vx-section-label">// ENTER THE VORTEX</div>
      <h2 class="vx-section-h2">Shop the<br><em>Collection</em></h2>
      <a class="vx-view-all" href="/collections/vortex">View All &#8594;</a>
    </div>

    <div class="vx-product-grid" id="vx-product-grid">
      {%- assign vortex_products = vortex_col.products -%}
      {%- for product in vortex_products limit: 12 -%}
        <a class="hand-card vx-card" href="{{ product.url }}">
          <div class="imgwrap">
            <span class="tag">{{ product.type | default: 'Vortex' }}</span>
            {%- if product.featured_image -%}
              <img src="{{ product.featured_image | image_url: width: 600 }}" alt="{{ product.featured_image.alt | default: product.title }}" loading="lazy" width="600" height="600" />
            {%- else -%}
              <div class="vx-no-img">VORTEX</div>
            {%- endif -%}
            <span class="quick">Quick Add &#8594;</span>
          </div>
          <div class="body">
            <div class="vendor">Vortex</div>
            <div class="name">{{ product.title }}</div>
            <div class="row2">
              <div class="price">{{ product.price | money }}</div>
              {%- if product.compare_at_price > product.price -%}
                <span class="vx-sale-badge">SALE</span>
              {%- endif -%}
            </div>
          </div>
        </a>
      {%- else -%}
        <!-- Fallback if collection is empty -->
        <a class="hand-card vx-card" href="/products/vortex-info-the-robot-t-shirt-grey-edition">
          <div class="imgwrap">
            <span class="tag">T-Shirt</span>
            <img src="https://cdn.shopify.com/s/files/1/0737/7397/3795/files/VORTEX-6_ba729893-2335-4411-8fb5-bbd591f745ac.webp?v=1768032125" alt="VORTEX INFO THE ROBOT T-shirt Grey Edition" loading="lazy" width="600" height="600" />
            <span class="quick">Quick Add &#8594;</span>
          </div>
          <div class="body">
            <div class="vendor">Vortex</div>
            <div class="name">VORTEX - INFO THE ROBOT T-shirt Grey Edition</div>
            <div class="row2"><div class="price">£29.99</div></div>
          </div>
        </a>
        <a class="hand-card vx-card" href="/products/vortex-energize">
          <div class="imgwrap">
            <span class="tag">T-Shirt</span>
            <img src="https://cdn.shopify.com/s/files/1/0737/7397/3795/files/VORTEX-8_3_ad2972b4-c48d-463f-ac25-b295b3aedb7f.png?v=1761074951" alt="VORTEX ENERGIZE T-shirt" loading="lazy" width="600" height="600" />
            <span class="quick">Quick Add &#8594;</span>
          </div>
          <div class="body">
            <div class="vendor">Vortex</div>
            <div class="name">VORTEX - ENERGIZE T-shirt</div>
            <div class="row2"><div class="price">£29.99</div></div>
          </div>
        </a>
        <a class="hand-card vx-card" href="/products/vortex-stargate-front-and-back-print-organic-t-shirt">
          <div class="imgwrap">
            <span class="tag">T-Shirt</span>
            <img src="https://cdn.shopify.com/s/files/1/0737/7397/3795/files/VORTEX-2_4.png?v=1753641238" alt="VORTEX STARGATE Organic T-Shirt" loading="lazy" width="600" height="600" />
            <span class="quick">Quick Add &#8594;</span>
          </div>
          <div class="body">
            <div class="vendor">Vortex</div>
            <div class="name">VORTEX - STARGATE front and back print Organic T-Shirt</div>
            <div class="row2"><div class="price">£35.00</div></div>
          </div>
        </a>
        <a class="hand-card vx-card" href="/products/vortex-classic-logo-zip-hood">
          <div class="imgwrap">
            <span class="tag">Zip Hood</span>
            <img src="https://cdn.shopify.com/s/files/1/0737/7397/3795/files/VORTEX-39.png?v=1758116570" alt="VORTEX CLASSIC LOGO Zip Hood" loading="lazy" width="600" height="600" />
            <span class="quick">Quick Add &#8594;</span>
          </div>
          <div class="body">
            <div class="vendor">Vortex</div>
            <div class="name">VORTEX - CLASSIC LOGO Zip Hood</div>
            <div class="row2"><div class="price">£79.99</div></div>
          </div>
        </a>
      {%- endfor -%}
    </div>

  </div>
</section>

<!-- ============================================================
     CLOSING CTA — Cosmic
     ============================================================ -->
<section class="vx-cta-section">
  <div class="vx-cta-orbit" aria-hidden="true"></div>
  <div class="vx-cta-inner">
    <div class="vx-cta-symbol" aria-hidden="true">
      <div class="vx-cta-ring vx-cta-r1"></div>
      <div class="vx-cta-ring vx-cta-r2"></div>
      <div class="vx-cta-dot"></div>
    </div>
    <div class="vx-cta-text">
      <h2 class="vx-cta-h2">Step into<br><em>another dimension.</em></h2>
      <p>Vortex. Cosmic streetwear from Camden's underground. Organic fabrics, otherworldly prints, no compromises.</p>
      <a class="vx-cta-primary" href="#vx-shop">Shop All Vortex &#8594;</a>
    </div>
  </div>
</section>

<!-- ============================================================
     STYLES
     ============================================================ -->
<style>
/* ---- TOKENS ---- */
:root {
  --vx-dark: #050510;
  --vx-darker: #020208;
  --vx-purple: #7c3aed;
  --vx-cyan: #06b6d4;
  --vx-magenta: #d946ef;
  --vx-purple-dim: rgba(124,58,237,.15);
  --vx-cyan-dim: rgba(6,182,212,.12);
  --vx-purple-glow: rgba(124,58,237,.3);
  --vx-cyan-glow: rgba(6,182,212,.25);
  --vx-white: #f0f4ff;
  --vx-grey: rgba(240,244,255,.45);
  --vx-border: rgba(124,58,237,.15);
}

/* ---- HERO ---- */
.vx-hero {
  position: relative;
  min-height: 100vh;
  background: var(--vx-dark);
  display: flex;
  align-items: center;
  overflow: hidden;
  padding: 120px 40px 80px;
}

/* Starfield layers */
.vx-stars { position: absolute; inset: 0; pointer-events: none; }
.vx-stars-layer {
  position: absolute; inset: 0;
  background-image: radial-gradient(1px 1px at var(--x,50%) var(--y,50%), rgba(255,255,255,.8) 0%, transparent 100%);
  background-size: 200px 200px;
}
.vx-s1 {
  --x: 20%; --y: 30%;
  background-image:
    radial-gradient(1px 1px at 10% 15%, rgba(255,255,255,.9) 0%, transparent 100%),
    radial-gradient(1px 1px at 25% 45%, rgba(255,255,255,.7) 0%, transparent 100%),
    radial-gradient(1px 1px at 60% 20%, rgba(255,255,255,.8) 0%, transparent 100%),
    radial-gradient(1px 1px at 80% 60%, rgba(255,255,255,.6) 0%, transparent 100%),
    radial-gradient(1px 1px at 45% 75%, rgba(255,255,255,.9) 0%, transparent 100%),
    radial-gradient(1px 1px at 90% 10%, rgba(255,255,255,.7) 0%, transparent 100%),
    radial-gradient(1px 1px at 35% 90%, rgba(255,255,255,.5) 0%, transparent 100%),
    radial-gradient(1px 1px at 70% 40%, rgba(255,255,255,.8) 0%, transparent 100%),
    radial-gradient(1px 1px at 15% 65%, rgba(255,255,255,.6) 0%, transparent 100%),
    radial-gradient(1px 1px at 55% 55%, rgba(255,255,255,.9) 0%, transparent 100%);
  animation: vx-drift1 60s linear infinite;
}
.vx-s2 {
  background-image:
    radial-gradient(1.5px 1.5px at 5% 80%, rgba(124,58,237,.9) 0%, transparent 100%),
    radial-gradient(1.5px 1.5px at 40% 10%, rgba(6,182,212,.8) 0%, transparent 100%),
    radial-gradient(1.5px 1.5px at 75% 85%, rgba(217,70,239,.7) 0%, transparent 100%),
    radial-gradient(1.5px 1.5px at 20% 50%, rgba(124,58,237,.6) 0%, transparent 100%),
    radial-gradient(1.5px 1.5px at 85% 30%, rgba(6,182,212,.9) 0%, transparent 100%),
    radial-gradient(1.5px 1.5px at 50% 95%, rgba(217,70,239,.8) 0%, transparent 100%),
    radial-gradient(1.5px 1.5px at 65% 5%, rgba(124,58,237,.7) 0%, transparent 100%),
    radial-gradient(1.5px 1.5px at 30% 70%, rgba(6,182,212,.6) 0%, transparent 100%);
  animation: vx-drift2 80s linear infinite;
}
.vx-s3 {
  background-image:
    radial-gradient(2px 2px at 15% 25%, rgba(255,255,255,.4) 0%, transparent 100%),
    radial-gradient(2px 2px at 70% 70%, rgba(255,255,255,.3) 0%, transparent 100%),
    radial-gradient(2px 2px at 45% 40%, rgba(255,255,255,.5) 0%, transparent 100%),
    radial-gradient(2px 2px at 90% 90%, rgba(255,255,255,.4) 0%, transparent 100%),
    radial-gradient(2px 2px at 5% 55%, rgba(255,255,255,.3) 0%, transparent 100%);
  animation: vx-drift3 100s linear infinite;
}
@keyframes vx-drift1 { from { transform: translateY(0); } to { transform: translateY(-100px); } }
@keyframes vx-drift2 { from { transform: translateY(0) translateX(0); } to { transform: translateY(-80px) translateX(30px); } }
@keyframes vx-drift3 { from { transform: translateY(0); } to { transform: translateY(-60px); } }

/* Orbital rings */
.vx-orbit {
  position: absolute;
  border-radius: 50%;
  border: 1px solid;
  pointer-events: none;
  animation: vx-spin linear infinite;
}
.vx-orbit1 {
  width: 600px; height: 600px;
  top: 50%; left: 70%;
  transform: translate(-50%, -50%);
  border-color: rgba(124,58,237,.2);
  animation-duration: 20s;
}
.vx-orbit2 {
  width: 900px; height: 900px;
  top: 50%; left: 70%;
  transform: translate(-50%, -50%);
  border-color: rgba(6,182,212,.12);
  animation-duration: 35s;
  animation-direction: reverse;
}
.vx-orbit3 {
  width: 1200px; height: 1200px;
  top: 50%; left: 70%;
  transform: translate(-50%, -50%);
  border-color: rgba(217,70,239,.08);
  animation-duration: 55s;
}
@keyframes vx-spin { from { transform: translate(-50%, -50%) rotate(0deg); } to { transform: translate(-50%, -50%) rotate(360deg); } }

/* Vortex core */
.vx-core {
  position: absolute;
  right: 15%;
  top: 50%;
  transform: translateY(-50%);
  width: 200px; height: 200px;
  pointer-events: none;
}
.vx-core-ring {
  position: absolute;
  border-radius: 50%;
  border: 2px solid;
  top: 50%; left: 50%;
  transform: translate(-50%, -50%);
  animation: vx-pulse 3s ease-in-out infinite;
}
.vx-cr1 { width: 60px; height: 60px; border-color: var(--vx-purple); animation-delay: 0s; }
.vx-cr2 { width: 110px; height: 110px; border-color: var(--vx-cyan); animation-delay: .5s; }
.vx-cr3 { width: 160px; height: 160px; border-color: var(--vx-magenta); animation-delay: 1s; }
.vx-core-dot {
  position: absolute;
  width: 16px; height: 16px;
  border-radius: 50%;
  background: var(--vx-cyan);
  top: 50%; left: 50%;
  transform: translate(-50%, -50%);
  box-shadow: 0 0 20px var(--vx-cyan), 0 0 40px var(--vx-purple);
  animation: vx-pulse 2s ease-in-out infinite;
}
@keyframes vx-pulse {
  0%, 100% { opacity: 1; transform: translate(-50%, -50%) scale(1); }
  50% { opacity: .6; transform: translate(-50%, -50%) scale(1.1); }
}

/* Hero content */
.vx-hero-content {
  position: relative;
  z-index: 2;
  max-width: 700px;
}
.vx-eyebrow {
  display: flex;
  align-items: center;
  gap: 12px;
  font-size: 11px;
  letter-spacing: .2em;
  text-transform: uppercase;
  color: var(--vx-cyan);
  margin-bottom: 24px;
}
.vx-signal {
  display: inline-block;
  width: 24px; height: 2px;
  background: var(--vx-cyan);
  position: relative;
}
.vx-signal::before {
  content: '';
  position: absolute;
  width: 6px; height: 6px;
  border-radius: 50%;
  background: var(--vx-cyan);
  top: -2px; right: -8px;
  animation: vx-blink 1.5s ease-in-out infinite;
}
@keyframes vx-blink { 0%, 100% { opacity: 1; } 50% { opacity: 0; } }

.vx-hero-h1 {
  font-size: clamp(64px, 12vw, 140px);
  font-weight: 900;
  line-height: .9;
  letter-spacing: -.03em;
  color: var(--vx-white);
  margin: 0 0 24px;
  text-transform: uppercase;
}
.vx-word {
  display: block;
  background: linear-gradient(135deg, var(--vx-purple) 0%, var(--vx-cyan) 50%, var(--vx-magenta) 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  filter: drop-shadow(0 0 30px rgba(124,58,237,.4));
}
.vx-hero-sub {
  font-size: 18px;
  line-height: 1.6;
  color: var(--vx-grey);
  margin: 0 0 40px;
  max-width: 500px;
}
.vx-hero-cta { display: flex; gap: 16px; flex-wrap: wrap; }
.vx-btn-primary {
  display: inline-block;
  padding: 16px 32px;
  background: linear-gradient(135deg, var(--vx-purple), var(--vx-cyan));
  color: #fff;
  text-decoration: none;
  font-size: 14px;
  font-weight: 700;
  letter-spacing: .1em;
  text-transform: uppercase;
  border-radius: 2px;
  transition: opacity .2s, transform .2s;
  box-shadow: 0 0 30px var(--vx-purple-glow);
}
.vx-btn-primary:hover { opacity: .85; transform: translateY(-2px); }
.vx-btn-ghost {
  display: inline-block;
  padding: 16px 32px;
  border: 1px solid rgba(124,58,237,.4);
  color: var(--vx-white);
  text-decoration: none;
  font-size: 14px;
  font-weight: 700;
  letter-spacing: .1em;
  text-transform: uppercase;
  border-radius: 2px;
  transition: border-color .2s, background .2s;
}
.vx-btn-ghost:hover { border-color: var(--vx-cyan); background: var(--vx-cyan-dim); }

/* Scroll hint */
.vx-scroll-hint {
  position: absolute;
  bottom: 40px;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8px;
}
.vx-scroll-line {
  display: block;
  width: 1px; height: 40px;
  background: linear-gradient(to bottom, var(--vx-purple), transparent);
  animation: vx-scroll-anim 2s ease-in-out infinite;
}
@keyframes vx-scroll-anim { 0%, 100% { opacity: 1; transform: scaleY(1); } 50% { opacity: .4; transform: scaleY(.6); } }
.vx-scroll-text {
  font-size: 9px;
  letter-spacing: .3em;
  color: var(--vx-grey);
  text-transform: uppercase;
}

/* ---- SIGNAL STRIP ---- */
.vx-signal-strip {
  background: linear-gradient(135deg, var(--vx-purple), var(--vx-cyan));
  overflow: hidden;
  padding: 14px 0;
}
.vx-signal-track {
  display: flex;
  gap: 32px;
  white-space: nowrap;
  animation: vx-ticker 30s linear infinite;
  font-size: 11px;
  font-weight: 700;
  letter-spacing: .15em;
  text-transform: uppercase;
  color: #fff;
}
.vx-signal-track span { flex-shrink: 0; }
@keyframes vx-ticker { from { transform: translateX(0); } to { transform: translateX(-50%); } }

/* ---- STORY SECTION ---- */
.vx-story-section {
  background: var(--vx-darker);
  padding: 100px 40px;
}
.vx-story-inner {
  max-width: 1200px;
  margin: 0 auto;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 80px;
  align-items: center;
}
.vx-story-visual {
  position: relative;
  height: 400px;
}
.vx-planet {
  position: absolute;
  border-radius: 50%;
}
.vx-p1 {
  width: 180px; height: 180px;
  background: radial-gradient(circle at 35% 35%, var(--vx-purple), #1a0040);
