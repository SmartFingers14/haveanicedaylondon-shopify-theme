<section style="padding:80px 24px">
  <div class="container">
    <div class="section-head">
      <div>
        <span class="eyebrow">All Collections</span>
        <h2 class="h2 reveal">The <em>house</em>.</h2>
      </div>
    </div>
    <div class="brands-rail">
      {%- for collection in collections -%}
        <a href="{{ collection.url }}" class="brand-tile bt-hand reveal">
          <span class="num">{{ forloop.index | prepend: '0' | slice: -2, 2 }}</span>
          <span class="arr">â†’</span>
          <div class="vibe">{{ collection.title | upcase | truncate: 8 }}</div>
          <span class="label">{{ collection.title }}</span>
        </a>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{ "name": "Collections list", "settings": [] }
{% endschema %}
