        { "type": "text", "id": "text", "label": "Ticker text", "default": "Have A Nice Day" }
      ]
    }
  ],
  "presets": [
    {
      "name": "V3 Ticker",
      "blocks": [
        { "type": "item", "settings": { "text": "Have A Nice Day" } },
        { "type": "item", "settings": { "text": "Sam The Man" } },
