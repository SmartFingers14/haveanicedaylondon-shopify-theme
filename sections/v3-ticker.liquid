<div class="hand-ticker">
  <div class="track">
    {% if section.blocks.size > 0 %}
      {% for block in section.blocks %}
        {% if block.type == 'item' %}
          <span {{ block.shopify_attributes }}>{{ block.settings.text }}</span>
        {% endif %}
      {% endfor %}
      {% for block in section.blocks %}
        {% if block.type == 'item' %}
          <span>{{ block.settings.text }}</span>
        {% endif %}
      {% endfor %}
    {% else %}
      <span>Have A Nice Day</span>
      <span>Sam The Man</span>
      <span>Shurl The Girl</span>
      <span>Handspun Records</span>
      <span>Dready Original</span>
      <span>BTKA</span>
      <span>Vortex</span>
      <span>Funky Dog</span>
      <span>Don't Do The Dodo</span>
