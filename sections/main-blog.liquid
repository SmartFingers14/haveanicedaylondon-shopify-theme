<section style="padding:80px 24px">
  <div class="container">
    <div class="section-head">
      <div>
        <span class="eyebrow">Journal</span>
        <h2 class="h2 reveal">{{ blog.title }}</h2>
      </div>
    </div>
    <div class="why-grid">
      {%- for article in blog.articles -%}
        <a href="{{ article.url }}" class="why-card reveal" style="display:block">
          <div class="ic">â˜…</div>
          <h4>{{ article.title }}</h4>
          <p>{{ article.excerpt_or_content | strip_html | truncate: 140 }}</p>
        </a>
      {%- endfor -%}
    </div>
  </div>
</section>
{% schema %}{ "name": "Blog", "settings": [] }{% endschema %}
