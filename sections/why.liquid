<section class="why">
  <div class="container">
    <div class="section-head">
      <div>
        <span class="eyebrow">{{ section.settings.eyebrow }}</span>
        <h2 class="h2 reveal">{{ section.settings.heading_pre }} <em>{{ section.settings.heading_em }}</em>. {{ section.settings.heading_post }}</h2>
      </div>
      <p class="reveal">{{ section.settings.subhead }}</p>
    </div>

    <div class="why-grid">
      {%- for block in section.blocks -%}
        <div class="why-card reveal" {{ block.shopify_attributes }}>
          <div class="ic">{{ block.settings.icon }}</div>
          <h4>{{ block.settings.title }}</h4>
          <p>{{ block.settings.text }}</p>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Why us",
  "max_blocks": 8,
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Why Have A Nice Day" },
    { "type": "text", "id": "heading_pre", "label": "Heading before", "default": "Tread" },
    { "type": "text", "id": "heading_em", "label": "Highlight", "default": "lightly" },
    { "type": "text", "id": "heading_post", "label": "Heading after", "default": "Wear loudly." },
    { "type": "textarea", "id": "subhead", "label": "Sub-heading", "default": "Our integrity is as important as our products." }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Card",
      "settings": [
