<section id="brands" class="brands">
  <div class="container">
    <div class="section-head">
      <div>
        <span class="eyebrow">{{ section.settings.eyebrow }}</span>
        <h2 class="h2 reveal">{{ section.settings.heading_pre }} <em>{{ section.settings.heading_em }}</em>.<br>{{ section.settings.heading_post }}</h2>
      </div>
      <p class="reveal">{{ section.settings.subhead }}</p>
    </div>

    <div class="brands-rail">
      {%- for block in section.blocks -%}
        <a href="{{ block.settings.link }}" class="brand-tile bt-{{ block.settings.style }} reveal" {{ block.shopify_attributes }}>
          <span class="num">{{ block.settings.num }}</span>
          <span class="arr">â†’</span>
          <div class="vibe">{{ block.settings.vibe }}</div>
          <span class="label">{{ block.settings.label }}</span>
        </a>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Brands rail",
  "max_blocks": 12,
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Our Brands Â· 9 Worlds" },
    { "type": "text", "id": "heading_pre", "label": "Heading before highlight", "default": "One" },
    { "type": "text", "id": "heading_em",  "label": "Highlighted word", "default": "house" },
    { "type": "text", "id": "heading_post","label": "Heading after", "default": "Nine independent brands." },
    { "type": "textarea", "id": "subhead", "label": "Sub-heading", "default": "Have A Nice Day is also a creative house." }
  ],
  "blocks": [
    {
      "type": "brand",
      "name": "Brand tile",
      "settings": [
        { "type": "text", "id": "num",   "label": "Number", "default": "01" },
        { "type": "text", "id": "vibe",  "label": "Vibe word", "default": "â˜»" },
        { "type": "text", "id": "label", "label": "Brand name", "default": "Have A Nice Day" },
        { "type": "url",  "id": "link",  "label": "Link" },
        { "type": "select", "id": "style", "label": "Color style",
          "options": [
            { "value": "hand",      "label": "Yellow (hand)" },
            { "value": "dready",    "label": "Black/yellow (dready)" },
            { "value": "sista",     "label": "Pink (sista)" },
            { "value": "handspun",  "label": "Sky (handspun)" },
            { "value": "btka",      "label": "Soft pink (btka)" },
            { "value": "vortex",    "label": "Yellow (vortex)" },
            { "value": "funky",     "label": "Pink (funky)" },
            { "value": "dodo",      "label": "Black/pink (dodo)" },
            { "value": "incu",      "label": "Outline (incubator)" }
          ],
          "default": "hand"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Brands rail",
      "blocks": [
        { "type": "brand", "settings": { "num": "01", "vibe": "â˜»",     "label": "Have A Nice Day",  "style": "hand" } },
        { "type": "brand", "settings": { "num": "02", "vibe": "DREAD", "label": "Dready",           "style": "dready" } },
        { "type": "brand", "settings": { "num": "03", "vibe": "SIS",   "label": "Sista",            "style": "sista" } },
        { "type": "brand", "settings": { "num": "04", "vibe": "RECORDS","label": "Handspun Records","style": "handspun" } },
        { "type": "brand", "settings": { "num": "05", "vibe": "BTKA",  "label": "BTKA",             "style": "btka" } },
        { "type": "brand", "settings": { "num": "06", "vibe": "VRTX",  "label": "Vortex",           "style": "vortex" } },
        { "type": "brand", "settings": { "num": "07", "vibe": "FUNKY DOG", "label": "Funky Dog",    "style": "funky" } },
        { "type": "brand", "settings": { "num": "08", "vibe": "DODO",  "label": "Don\u0027t Do The Dodo", "style": "dodo" } },
        { "type": "brand", "settings": { "num": "09", "vibe": "NEW",   "label": "Incubator",        "style": "incu" } }
      ]
    }
  ]
}
{% endschema %}
