<section style="padding:80px 24px">
  <div class="container" style="max-width:780px">
    <div class="section-head">
      <div>
        <span class="eyebrow">{{ article.published_at | date: '%B %d, %Y' }}</span>
        <h1 class="h2 reveal">{{ article.title }}</h1>
      </div>
    </div>
    {%- if article.image -%}
      <img src="{{ article.image | image_url: width: 1400 }}" alt="{{ article.title | escape }}" style="width:100%;border-radius:18px;border:3px solid var(--ink);box-shadow:14px 14px 0 var(--pink);margin:30px 0">
    {%- endif -%}
    <div class="rte" style="font-size:16px;line-height:1.7;color:var(--ink-soft)">{{ article.content }}</div>
  </div>
</section>
{% schema %}{ "name": "Article", "settings": [] }{% endschema %}
