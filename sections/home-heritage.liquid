<section style="background:#F5F1E8;color:#000;padding:90px 24px;border-bottom:6px solid #000">
  <div style="max-width:1400px;margin:0 auto;display:grid;grid-template-columns:1.1fr 1fr;gap:60px;align-items:center">
    <div>
      <p style="font-family:'Permanent Marker',cursive;font-size:28px;color:#FF69B4;transform:rotate(-3deg);margin-bottom:14px">{{ section.settings.scribble }}</p>
      <h2 style="font-family:'Fjalla One',sans-serif;font-size:clamp(56px,9vw,140px);line-height:.85;text-transform:uppercase;letter-spacing:-.02em">
        <span>{{ section.settings.big_top }}</span><br>
        <span style="background:#FFD400;padding:0 10px">{{ section.settings.big_mid }}</span><br>
        <span>{{ section.settings.big_bot }}</span>
      </h2>
    </div>
    <div>
      <p style="font-family:'Bungee',sans-serif;font-size:11px;letter-spacing:.22em;text-transform:uppercase;color:#FF69B4">{{ section.settings.eyebrow }}</p>
      <h3 style="font-family:'Fjalla One',sans-serif;font-size:clamp(32px,4vw,52px);line-height:1;text-transform:uppercase;margin:14px 0 22px">{{ section.settings.heading }}</h3>
      <p style="font-size:17px;line-height:1.6;color:#333">{{ section.settings.body }}</p>
      <p style="font-family:'Permanent Marker',cursive;font-size:22px;margin-top:20px;color:#000">{{ section.settings.signed }}</p>

      <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:20px;margin-top:36px;border-top:2px solid #000;padding-top:28px">
        {%- for block in section.blocks -%}
          <div {{ block.shopify_attributes }}>
            <div style="font-family:'Fjalla One',sans-serif;font-size:36px;line-height:1;color:#FF69B4">{{ block.settings.num }}</div>
            <div style="font-family:'Bungee',sans-serif;font-size:10px;letter-spacing:.2em;text-transform:uppercase;color:#444;margin-top:8px">{{ block.settings.label }}</div>
          </div>
        {%- endfor -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Home heritage",
  "max_blocks": 4,
  "settings": [
    { "type": "text", "id": "scribble", "label": "Scribble", "default": "back, baby ☻" },
    { "type": "text", "id": "big_top", "label": "Big text 1", "default": "17 Years." },
    { "type": "text", "id": "big_mid", "label": "Big text 2 (highlighted)", "default": "Now Back." },
    { "type": "text", "id": "big_bot", "label": "Big text 3", "default": "." },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Today's Story" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Born in a Camden corridor. Adopted by ravers." },
    { "type": "textarea", "id": "body", "label": "Body", "default": "We started at the back of American Rag Store, Camden Market — a corridor smelling of incense and 12-inch records. The smiley was a sticker before it was a t-shirt. The t-shirt became a culture. After 17 years away, the architects are bringing it back — same studio, same ethos, organic cotton this time." },
    { "type": "text", "id": "signed", "label": "Signed", "default": "— The Architects ☻" }
  ],
  "blocks": [
    {
      "type": "stat",
      "name": "Stat",
      "settings": [
        { "type": "text", "id": "num",   "label": "Number", "default": "1990" },
        { "type": "text", "id": "label", "label": "Label",  "default": "Camden Origin" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Home heritage",
      "blocks": [
        { "type": "stat", "settings": { "num": "1990", "label": "Camden Origin" } },
        { "type": "stat", "settings": { "num": "9",    "label": "Sub-Brands" } },
        { "type": "stat", "settings": { "num": "100%", "label": "Organic Cotton" } }
      ]
    }
  ]
}
{% endschema %}
