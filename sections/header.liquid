      "label": "Nav link 4 label (optional)"
    },
    {
      "type": "url",
      "id": "nav4_link",
      "label": "Nav link 4 URL"
    },
    {
      "type": "text",
      "id": "nav5_label",
      "label": "Nav link 5 label (optional)"
    },
    {
      "type": "url",
      "id": "nav5_link",
      "label": "Nav link 5 URL"
    }
  ]
}
{% endschema %}
