<!-- HAVE A NICE DAY — Header: Logo Left, Nav Right -->
<style>
  /* ===== ANNOUNCE BAR ===== */
  .hand-announce {
    background: var(--ink);
    color: #fff;
    padding: 10px 0;
    text-align: center;
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: .18em;
    text-transform: uppercase;
    position: relative;
    z-index: 80;
  }

  /* ===== NAV ===== */
  .hand-nav {
    position: sticky;
    top: 0;
    z-index: 70;
    background: rgba(244, 241, 234, .97);
    backdrop-filter: saturate(160%) blur(12px);
    -webkit-backdrop-filter: saturate(160%) blur(12px);
    border-bottom: 1px solid rgba(0,0,0,.1);
    transition: box-shadow .3s ease;
  }
  .hand-nav.scrolled {
    box-shadow: 0 2px 20px rgba(0,0,0,.08);
  }
  .hand-nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 68px;
    max-width: var(--maxw);
    margin: 0 auto;
    padding: 0 32px;
    gap: 24px;
  }

  /* Left: Logo */
  .hand-logo {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: var(--ink);
    line-height: 1;
    flex-shrink: 0;
  }
  .hand-logo .l1 {
    font-family: 'Anton', Impact, sans-serif;
    font-size: 19px;
    text-transform: uppercase;
    letter-spacing: .02em;
  }
  .hand-logo .l2 {
    font-family: var(--mono);
    font-size: 9px;
    letter-spacing: .22em;
    text-transform: uppercase;
    color: #999;
    margin-top: 3px;
  }

  /* Right: nav links + icons */
  .hand-nav-right {
    display: flex;
    align-items: center;
    gap: 4px;
  }

  /* Nav links */
  .hand-nav-link {
    font-family: var(--mono);
    text-transform: uppercase;
    font-size: 11px;
    letter-spacing: .18em;
    font-weight: 500;
    color: var(--ink);
    padding: 8px 14px;
    text-decoration: none;
    border-bottom: 1.5px solid transparent;
    transition: border-color .2s, color .2s;
    white-space: nowrap;
  }
  .hand-nav-link:hover {
    border-bottom-color: var(--ink);
  }

  /* Divider between links and icons */
  .hand-nav-divider {
    width: 1px;
    height: 20px;
    background: rgba(0,0,0,.15);
    margin: 0 8px;
    flex-shrink: 0;
  }

  /* Icon buttons */
  .hand-icon-btn {
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: none;
    border: none;
    cursor: pointer;
    color: var(--ink);
    transition: color .2s;
    text-decoration: none;
    font-size: 18px;
    flex-shrink: 0;
  }
  .hand-icon-btn:hover { color: var(--pink); }

  /* Bag button */
  .hand-bag-btn {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    padding: 9px 16px;
    background: var(--ink);
    color: #fff;
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: .14em;
    text-transform: uppercase;
    transition: background .2s;
    border: none;
    text-decoration: none;
    cursor: pointer;
    flex-shrink: 0;
  }
  .hand-bag-btn:hover { background: var(--pink); }
  .hand-bag-count {
    font-weight: 700;
    min-width: 14px;
    text-align: center;
  }

  /* Burger (mobile only) */
  .hand-burger {
    display: none;
    width: 40px;
    height: 40px;
    align-items: center;
    justify-content: center;
    border: 1px solid rgba(0,0,0,.2);
    background: none;
    cursor: pointer;
    flex-direction: column;
    gap: 5px;
    padding: 10px;
    flex-shrink: 0;
  }
  .hand-burger span {
    display: block;
    width: 18px;
    height: 1.5px;
    background: var(--ink);
  }

  /* ===== MOBILE MENU ===== */
  .hand-mob-menu {
    position: fixed;
    top: 0;
    right: 0;
    bottom: 0;
    width: min(340px, 88vw);
    background: var(--ink);
    color: #fff;
    z-index: 500;
    transform: translateX(100%);
    transition: transform .4s cubic-bezier(.22,1,.36,1);
    display: flex;
    flex-direction: column;
  }
  .hand-mob-menu.open { transform: translateX(0); }
  .hand-mob-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 22px 24px;
    border-bottom: 1px solid rgba(255,255,255,.08);
  }
  .hand-mob-logo {
    font-family: 'Anton', Impact, sans-serif;
    font-size: 17px;
    text-transform: uppercase;
    color: #fff;
  }
  .hand-mob-close {
    width: 38px;
    height: 38px;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px solid rgba(255,255,255,.15);
    background: none;
    color: #fff;
    font-size: 16px;
    cursor: pointer;
    transition: background .2s;
  }
  .hand-mob-close:hover { background: var(--pink); border-color: var(--pink); }
  .hand-mob-body {
    flex: 1;
    padding: 28px 24px;
    display: flex;
    flex-direction: column;
    overflow-y: auto;
  }
  .hand-mob-link {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 16px 0;
    font-family: var(--body);
    font-size: 18px;
    font-weight: 500;
    color: #fff;
    border-bottom: 1px solid rgba(255,255,255,.07);
    text-decoration: none;
    transition: color .2s, padding-left .2s;
  }
  .hand-mob-link:hover { color: var(--pink); padding-left: 6px; }
  .hand-mob-link .arr { opacity: .4; font-size: 14px; }
  .hand-mob-foot {
    padding: 20px 24px;
    border-top: 1px solid rgba(255,255,255,.08);
    display: flex;
    gap: 10px;
  }
  .hand-mob-foot a {
    flex: 1;
    padding: 13px;
    text-align: center;
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: .18em;
    text-transform: uppercase;
    border: 1px solid rgba(255,255,255,.15);
    color: #fff;
    text-decoration: none;
    transition: background .2s;
  }
  .hand-mob-foot a:hover { background: var(--pink); border-color: var(--pink); }

  @media (max-width: 820px) {
    .hand-nav-inner { padding: 0 20px; }
    .hand-nav-links { display: none; }
    .hand-nav-divider { display: none; }
    .hand-burger { display: flex; }
    .hand-bag-btn { padding: 9px 14px; }
  }
  @media (max-width: 480px) {
    .hand-logo .l2 { display: none; }
  }
</style>

<!-- Announcement Bar -->
{%- if section.settings.announce_text != blank -%}
  <div class="hand-announce">{{ section.settings.announce_text }}</div>
{%- endif -%}

<!-- Navigation -->
<nav class="hand-nav" id="handNav" role="navigation" aria-label="Main navigation">
  <div class="hand-nav-inner">

    <!-- Left: Logo -->
    <a class="hand-logo" href="{{ routes.root_url }}" aria-label="{{ shop.name }}">
      {%- if settings.logo != blank -%}
        <img src="{{ settings.logo | image_url: width: 220 }}" alt="{{ shop.name | escape }}" width="110" height="36" loading="eager">
      {%- else -%}
        <span class="l1">Have A Nice Day®</span>
        <span class="l2">London · Since 1990</span>
      {%- endif -%}
    </a>

    <!-- Right: Nav links + Search + Bag + Burger -->
    <div class="hand-nav-right">

      <!-- 3 Nav links -->
      <div class="hand-nav-links" style="display:flex;align-items:center;gap:2px;">
        <a class="hand-nav-link" href="/collections/all">Merchandise</a>
        <a class="hand-nav-link" href="/pages/about-us">About Us</a>
        <a class="hand-nav-link" href="/pages/contact">Contact</a>
      </div>

      <!-- Divider -->
      <div class="hand-nav-divider"></div>

      <!-- Search icon -->
      <button class="hand-icon-btn" data-open-search aria-label="Search">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
        </svg>
      </button>

      <!-- Bag button -->
      <a class="hand-bag-btn" href="{{ routes.cart_url }}" aria-label="Cart ({{ cart.item_count }} items)">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
          <path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/>
        </svg>
        <b class="hand-bag-count" id="handCartCount">{{ cart.item_count }}</b>
      </a>

      <!-- Mobile burger -->
      <button class="hand-burger" id="handBurger" aria-label="Open menu" aria-expanded="false">
        <span></span><span></span><span></span>
      </button>
    </div>
  </div>
</nav>

<!-- Mobile Menu -->
<div class="hand-mob-menu" id="handMobMenu" aria-hidden="true" role="dialog" aria-label="Mobile navigation">
  <div class="hand-mob-head">
    <div class="hand-mob-logo">Have A Nice Day®</div>
    <button class="hand-mob-close" id="handMobClose" aria-label="Close menu">&#x2715;</button>
  </div>
  <div class="hand-mob-body">
    <a class="hand-mob-link" href="/collections/all">Merchandise <span class="arr">&#x2192;</span></a>
    <a class="hand-mob-link" href="/pages/about-us">About Us <span class="arr">&#x2192;</span></a>
    <a class="hand-mob-link" href="/pages/contact">Contact <span class="arr">&#x2192;</span></a>
  </div>
  <div class="hand-mob-foot">
    <a href="#" data-open-search>Search</a>
    <a href="{{ routes.cart_url }}">Bag ({{ cart.item_count }})</a>
  </div>
</div>

<script>
(function() {
  var nav = document.getElementById('handNav');
  var burger = document.getElementById('handBurger');
  var mobMenu = document.getElementById('handMobMenu');
  var mobClose = document.getElementById('handMobClose');

  window.addEventListener('scroll', function() {
    if (nav) nav.classList.toggle('scrolled', window.scrollY > 40);
  }, { passive: true });

  if (burger && mobMenu) {
    burger.addEventListener('click', function() {
      mobMenu.classList.add('open');
      mobMenu.setAttribute('aria-hidden', 'false');
      burger.setAttribute('aria-expanded', 'true');
      document.body.style.overflow = 'hidden';
    });
  }

  function closeMob() {
    if (mobMenu) { mobMenu.classList.remove('open'); mobMenu.setAttribute('aria-hidden', 'true'); }
    if (burger) burger.setAttribute('aria-expanded', 'false');
    document.body.style.overflow = '';
  }

  if (mobClose) mobClose.addEventListener('click', closeMob);
  document.addEventListener('keydown', function(e) { if (e.key === 'Escape') closeMob(); });
  document.querySelectorAll('.hand-mob-link').forEach(function(a) {
    a.addEventListener('click', closeMob);
  });
})();
</script>

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "text",
      "id": "announce_text",
      "label": "Announcement bar text",
      "default": "FREE UK SHIPPING OVER £75 — ORGANIC COTTON — UK PRINTED"
    }
  ]
}
{% endschema %}
