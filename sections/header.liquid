<!-- HAVE A NICE DAY — Header matching reference design -->
<style>
  /* ===== TOP BAR ===== */
  .hand-topbar {
    background: var(--ink, #1a1a1a);
    color: #fff;
    height: 36px;
    display: flex;
    align-items: center;
    position: relative;
    z-index: 80;
  }
  .hand-topbar-inner {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    width: 100%;
    max-width: var(--maxw, 1400px);
    margin: 0 auto;
    padding: 0 28px;
  }
  .hand-topbar-left {
    display: flex;
    align-items: center;
    gap: 7px;
    font-family: var(--mono, 'Courier New', monospace);
    font-size: 10px;
    letter-spacing: .18em;
    text-transform: uppercase;
    color: #fff;
  }
  .hand-topbar-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #e91e8c;
    flex-shrink: 0;
    box-shadow: 0 0 6px 2px rgba(233, 30, 140, 0.8), 0 0 12px 4px rgba(233, 30, 140, 0.4);
    animation: hand-dot-pulse 2s ease-in-out infinite;
  }
  @keyframes hand-dot-pulse {
    0%, 100% { box-shadow: 0 0 6px 2px rgba(233, 30, 140, 0.8), 0 0 12px 4px rgba(233, 30, 140, 0.4); }
    50% { box-shadow: 0 0 10px 4px rgba(233, 30, 140, 1), 0 0 20px 8px rgba(233, 30, 140, 0.6); }
  }
  .hand-topbar-center {
    font-family: var(--mono, 'Courier New', monospace);
    font-size: 10px;
    letter-spacing: .18em;
    text-transform: uppercase;
    color: #fff;
    text-align: center;
    white-space: nowrap;
  }
  .hand-topbar-right {
    display: flex;
    align-items: center;
    gap: 16px;
    justify-content: flex-end;
    font-family: var(--mono, 'Courier New', monospace);
    font-size: 10px;
    letter-spacing: .14em;
    text-transform: uppercase;
    color: #fff;
  }
  .hand-topbar-right a {
    color: #fff;
    text-decoration: none;
    transition: color .2s;
  }
  .hand-topbar-right a:hover { color: #e91e8c; }
  .hand-topbar-sep {
    opacity: .35;
  }

  /* ===== MAIN NAV ===== */
  .hand-nav {
    position: sticky;
    top: 0;
    z-index: 70;
    background: #f4f1ea;
    border-bottom: 1px solid rgba(0,0,0,.1);
    transition: box-shadow .3s ease;
  }
  .hand-nav.scrolled {
    box-shadow: 0 2px 20px rgba(0,0,0,.08);
  }
  .hand-nav-inner {
    display: grid;
    grid-template-columns: 260px 1fr 260px;
    align-items: center;
    height: 80px;
    max-width: var(--maxw, 1400px);
    margin: 0 auto;
    padding: 0 32px;
    gap: 24px;
  }

  /* Logo */
  .hand-logo {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: var(--ink, #1a1a1a);
    line-height: 1;
    flex-shrink: 0;
  }
  .hand-logo .l1 {
    font-family: 'Anton', Impact, sans-serif;
    font-size: 18px;
    text-transform: uppercase;
    letter-spacing: .01em;
    font-weight: 900;
  }
  .hand-logo .l2 {
    font-family: var(--mono, 'Courier New', monospace);
    font-size: 9px;
    letter-spacing: .2em;
    text-transform: uppercase;
    color: #888;
    margin-top: 3px;
  }

  /* Center nav links */
  .hand-nav-links {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0;
  }
  .hand-nav-link {
    font-family: var(--mono, 'Courier New', monospace);
    text-transform: uppercase;
    font-size: 11px;
    letter-spacing: .16em;
    font-weight: 600;
    color: var(--ink, #1a1a1a);
    padding: 8px 18px;
    text-decoration: none;
    position: relative;
    transition: color .2s;
    white-space: nowrap;
  }
  .hand-nav-link::after {
    content: '';
    position: absolute;
    bottom: 4px;
    left: 18px;
    right: 18px;
    height: 1.5px;
    background: var(--ink, #1a1a1a);
    transform: scaleX(0);
    transition: transform .2s;
  }
  .hand-nav-link:hover::after { transform: scaleX(1); }
  .hand-nav-link:hover { color: var(--ink, #1a1a1a); }

  /* Right: search, account, bag */
  .hand-nav-actions {
    display: flex;
    align-items: center;
    gap: 4px;
    flex-shrink: 0;
    justify-content: flex-end;
  }
  .hand-action-btn {
    font-family: var(--mono, 'Courier New', monospace);
    font-size: 11px;
    letter-spacing: .14em;
    text-transform: uppercase;
    font-weight: 600;
    color: var(--ink, #1a1a1a);
    background: none;
    border: none;
    cursor: pointer;
    padding: 8px 12px;
    text-decoration: none;
    transition: color .2s;
    white-space: nowrap;
  }
  .hand-action-btn:hover { color: #e91e8c; }

  /* Bag button — dark pill */
  .hand-bag-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 10px 18px;
    background: var(--ink, #1a1a1a);
    color: #fff;
    font-family: var(--mono, 'Courier New', monospace);
    font-size: 11px;
    letter-spacing: .14em;
    text-transform: uppercase;
    font-weight: 700;
    transition: background .2s;
    border: none;
    text-decoration: none;
    cursor: pointer;
    margin-left: 8px;
  }
  .hand-bag-btn:hover { background: #e91e8c; }
  .hand-bag-dot {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: #e91e8c;
    flex-shrink: 0;
  }
  .hand-bag-btn:hover .hand-bag-dot { background: #fff; }

  /* Mobile burger */
  .hand-burger {
    display: none;
    width: 40px;
    height: 40px;
    align-items: center;
    justify-content: center;
    border: 1px solid rgba(0,0,0,.2);
    background: none;
    cursor: pointer;
    flex-direction: column;
    gap: 5px;
    padding: 10px;
    flex-shrink: 0;
  }
  .hand-burger span {
    display: block;
    width: 18px;
    height: 1.5px;
    background: var(--ink, #1a1a1a);
  }

  /* ===== MOBILE MENU ===== */
  .hand-mob-menu {
    position: fixed;
    top: 0; right: 0; bottom: 0;
    width: min(340px, 88vw);
    background: var(--ink, #1a1a1a);
    color: #fff;
    z-index: 500;
    transform: translateX(100%);
    transition: transform .4s cubic-bezier(.22,1,.36,1);
    display: flex;
    flex-direction: column;
  }
  .hand-mob-menu.open { transform: translateX(0); }
  .hand-mob-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 22px 24px;
    border-bottom: 1px solid rgba(255,255,255,.08);
  }
  .hand-mob-logo {
    font-family: 'Anton', Impact, sans-serif;
    font-size: 17px;
    text-transform: uppercase;
    color: #fff;
  }
  .hand-mob-close {
    width: 38px; height: 38px;
    display: flex; align-items: center; justify-content: center;
    border: 1px solid rgba(255,255,255,.15);
    background: none; color: #fff; font-size: 16px; cursor: pointer;
    transition: background .2s;
  }
  .hand-mob-close:hover { background: #e91e8c; border-color: #e91e8c; }
  .hand-mob-body {
    flex: 1; padding: 28px 24px;
    display: flex; flex-direction: column; overflow-y: auto;
  }
  .hand-mob-link {
    display: flex; align-items: center; justify-content: space-between;
    padding: 16px 0;
    font-family: var(--body, sans-serif);
    font-size: 18px; font-weight: 500; color: #fff;
    border-bottom: 1px solid rgba(255,255,255,.07);
    text-decoration: none;
    transition: color .2s, padding-left .2s;
  }
  .hand-mob-link:hover { color: #e91e8c; padding-left: 6px; }
  .hand-mob-link .arr { opacity: .4; font-size: 14px; }
  .hand-mob-foot {
    padding: 20px 24px;
    border-top: 1px solid rgba(255,255,255,.08);
    display: flex; gap: 10px;
  }
  .hand-mob-foot a {
    flex: 1; padding: 13px; text-align: center;
    font-family: var(--mono, monospace); font-size: 10px;
    letter-spacing: .18em; text-transform: uppercase;
    border: 1px solid rgba(255,255,255,.15); color: #fff;
    text-decoration: none; transition: background .2s;
  }
  .hand-mob-foot a:hover { background: #e91e8c; border-color: #e91e8c; }

  /* Responsive */
  @media (max-width: 900px) {
    .hand-nav-inner { grid-template-columns: auto 1fr; gap: 16px; padding: 0 20px; }
    .hand-nav-links { display: none; }
    .hand-nav-actions .hand-action-btn { display: none; }
    .hand-burger { display: flex; }
    .hand-bag-btn { margin-left: 0; }
  }
  @media (max-width: 600px) {
    .hand-topbar-left { display: none; }
    .hand-topbar-right { display: none; }
    .hand-topbar-inner { grid-template-columns: 1fr; }
    .hand-topbar-center { font-size: 9px; }
    .hand-logo .l2 { display: none; }
  }
</style>

<!-- TOP BAR -->
<div class="hand-topbar">
  <div class="hand-topbar-inner">
    <div class="hand-topbar-left">
      <span class="hand-topbar-dot"></span>
      {{ section.settings.topbar_left | default: 'EST. CAMDEN 1990' }}
    </div>
    <div class="hand-topbar-center">
      {%- if section.settings.announce_text != blank -%}
        {{ section.settings.announce_text }}
      {%- else -%}
        FREE UK SHIPPING OVER &pound;75 &mdash; ORGANIC COTTON &mdash; UK PRINTED
      {%- endif -%}
    </div>
    <div class="hand-topbar-right">
      <span>{{ section.settings.topbar_right | default: 'EN / £ GBP' }}</span>
      <span class="hand-topbar-sep">|</span>
      <a href="{{ section.settings.help_link | default: '/pages/help' }}">{{ section.settings.help_label | default: 'HELP' }}</a>
    </div>
  </div>
</div>

<!-- MAIN NAV -->
<nav class="hand-nav" id="handNav" role="navigation" aria-label="Main navigation">
  <div class="hand-nav-inner">

    <!-- Logo (left) -->
    <a class="hand-logo" href="{{ routes.root_url }}" aria-label="{{ shop.name }}">
      {%- if section.settings.logo != blank -%}
        <img src="{{ section.settings.logo | image_url: width: 300 }}" alt="{{ shop.name | escape }}" loading="eager" style="display:block;width:auto;height:60px;max-height:60px;object-fit:contain;padding:0;">
      {%- else -%}
        <img src="https://cdn.shopify.com/s/files/1/0737/7397/3795/t/16/assets/logo-hand2.webp?v=1777399896" alt="{{ shop.name | escape }}" loading="eager" style="display:block;width:auto;height:60px;max-height:60px;object-fit:contain;padding:0;">
      {%- endif -%}
    </a>

    <!-- Nav links (center) -->
    <div class="hand-nav-links">
      {%- if section.settings.nav1_label != blank -%}
        <a class="hand-nav-link" href="{{ section.settings.nav1_link | default: '/collections/all' }}">{{ section.settings.nav1_label }}</a>
      {%- endif -%}
      {%- if section.settings.nav2_label != blank -%}
        <a class="hand-nav-link" href="{{ section.settings.nav2_link | default: '/pages/about-us' }}">{{ section.settings.nav2_label }}</a>
      {%- endif -%}
      {%- if section.settings.nav3_label != blank -%}
        <a class="hand-nav-link" href="{{ section.settings.nav3_link | default: '/pages/contact' }}">{{ section.settings.nav3_label }}</a>
      {%- endif -%}
      {%- if section.settings.nav4_label != blank -%}
        <a class="hand-nav-link" href="{{ section.settings.nav4_link }}">{{ section.settings.nav4_label }}</a>
      {%- endif -%}
      {%- if section.settings.nav5_label != blank -%}
        <a class="hand-nav-link" href="{{ section.settings.nav5_link }}">{{ section.settings.nav5_label }}</a>
      {%- endif -%}
    </div>

    <!-- Actions (right) -->
    <div class="hand-nav-actions">
      <button class="hand-action-btn" data-open-search aria-label="Search">SEARCH</button>
      <a class="hand-action-btn" href="{{ routes.account_url }}">ACCOUNT</a>
      <a class="hand-bag-btn" href="{{ routes.cart_url }}" aria-label="Cart ({{ cart.item_count }} items)">
        BAG
        <span class="hand-bag-dot"></span>
        <span id="handCartCount">{{ cart.item_count }}</span>
      </a>
      <button class="hand-burger" id="handBurger" aria-label="Open menu" aria-expanded="false">
        <span></span><span></span><span></span>
      </button>
    </div>

  </div>
</nav>

<!-- Mobile Menu -->
<div class="hand-mob-menu" id="handMobMenu" aria-hidden="true" role="dialog" aria-label="Mobile navigation">
  <div class="hand-mob-head">
    <div class="hand-mob-logo">{{ shop.name }}</div>
    <button class="hand-mob-close" id="handMobClose" aria-label="Close menu">&#x2715;</button>
  </div>
  <div class="hand-mob-body">
    {%- if section.settings.nav1_label != blank -%}
      <a class="hand-mob-link" href="{{ section.settings.nav1_link | default: '/collections/all' }}">{{ section.settings.nav1_label }} <span class="arr">&#x2192;</span></a>
    {%- endif -%}
    {%- if section.settings.nav2_label != blank -%}
      <a class="hand-mob-link" href="{{ section.settings.nav2_link | default: '/pages/about-us' }}">{{ section.settings.nav2_label }} <span class="arr">&#x2192;</span></a>
    {%- endif -%}
    {%- if section.settings.nav3_label != blank -%}
      <a class="hand-mob-link" href="{{ section.settings.nav3_link | default: '/pages/contact' }}">{{ section.settings.nav3_label }} <span class="arr">&#x2192;</span></a>
    {%- endif -%}
    {%- if section.settings.nav4_label != blank -%}
      <a class="hand-mob-link" href="{{ section.settings.nav4_link }}">{{ section.settings.nav4_label }} <span class="arr">&#x2192;</span></a>
    {%- endif -%}
    {%- if section.settings.nav5_label != blank -%}
      <a class="hand-mob-link" href="{{ section.settings.nav5_link }}">{{ section.settings.nav5_label }} <span class="arr">&#x2192;</span></a>
    {%- endif -%}
  </div>
  <div class="hand-mob-foot">
    <a href="#" data-open-search>Search</a>
    <a href="{{ routes.cart_url }}">Bag ({{ cart.item_count }})</a>
  </div>
</div>

<script>
(function() {
  var nav = document.getElementById('handNav');
  var burger = document.getElementById('handBurger');
  var mobMenu = document.getElementById('handMobMenu');
  var mobClose = document.getElementById('handMobClose');

  window.addEventListener('scroll', function() {
    if (nav) nav.classList.toggle('scrolled', window.scrollY > 40);
  }, { passive: true });

  if (burger && mobMenu) {
    burger.addEventListener('click', function() {
      mobMenu.classList.add('open');
      mobMenu.setAttribute('aria-hidden', 'false');
      burger.setAttribute('aria-expanded', 'true');
      document.body.style.overflow = 'hidden';
    });
  }

  function closeMob() {
    if (mobMenu) { mobMenu.classList.remove('open'); mobMenu.setAttribute('aria-hidden', 'true'); }
    if (burger) burger.setAttribute('aria-expanded', 'false');
    document.body.style.overflow = '';
  }

  if (mobClose) mobClose.addEventListener('click', closeMob);
  document.addEventListener('keydown', function(e) { if (e.key === 'Escape') closeMob(); });
  document.querySelectorAll('.hand-mob-link').forEach(function(a) {
    a.addEventListener('click', closeMob);
  });
})();
</script>

