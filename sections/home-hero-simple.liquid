<section style="background:#FFD400;color:#000;padding:80px 24px;border-bottom:6px solid #000;text-align:center">
  <div style="max-width:1200px;margin:0 auto">
    <p style="font-family:'Bungee',sans-serif;font-size:13px;letter-spacing:.18em;text-transform:uppercase;margin-bottom:18px">{{ section.settings.eyebrow }}</p>
    <h1 style="font-family:'Fjalla One',sans-serif;font-size:clamp(48px,9vw,140px);line-height:.92;text-transform:uppercase;letter-spacing:-.01em;margin:0">
      {{ section.settings.heading_top }}<br>
      {{ section.settings.heading_mid }} <span style="background:#000;color:#FFD400;padding:0 16px">{{ section.settings.heading_highlight }}</span><br>
      {{ section.settings.heading_bot }}
    </h1>
    <p style="font-family:'Permanent Marker',cursive;font-size:24px;margin-top:18px">{{ section.settings.signed }}</p>
    <p style="max-width:560px;margin:24px auto 0;font-size:17px;line-height:1.5">{{ section.settings.subheading }}</p>
    <div style="margin-top:34px;display:flex;gap:14px;justify-content:center;flex-wrap:wrap">
      <a href="{{ section.settings.cta_link | default: '/collections/all' }}" style="background:#000;color:#FFD400;padding:18px 28px;border-radius:99px;font-family:'Bungee',sans-serif;font-size:13px;letter-spacing:.16em;text-transform:uppercase;text-decoration:none">{{ section.settings.cta_label }} →</a>
      <a href="{{ section.settings.cta_link_2 | default: '#about' }}" style="background:transparent;color:#000;padding:18px 28px;border-radius:99px;font-family:'Bungee',sans-serif;font-size:13px;letter-spacing:.16em;text-transform:uppercase;text-decoration:none;border:2px solid #000">{{ section.settings.cta_label_2 }}</a>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Home hero (simple)",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Established Camden 1990s · Back Again" },
    { "type": "text", "id": "heading_top", "label": "Heading line 1", "default": "The urban" },
    { "type": "text", "id": "heading_mid", "label": "Heading line 2", "default": "fashion" },
    { "type": "text", "id": "heading_highlight", "label": "Highlighted word", "default": "legend" },
    { "type": "text", "id": "heading_bot", "label": "Heading line 3", "default": "is back." },
    { "type": "text", "id": "signed", "label": "Signed line", "default": "— after 17 years away. ☻" },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "Born in a Camden market corridor at the height of the 90s rave scene. Have A Nice Day London is back — organic cotton, original graphics, nine sub-brands under one roof." },
    { "type": "text", "id": "cta_label", "label": "Primary CTA label", "default": "Shop The Originals" },
    { "type": "url",  "id": "cta_link",  "label": "Primary CTA link" },
    { "type": "text", "id": "cta_label_2", "label": "Secondary CTA label", "default": "Read The Story" },
    { "type": "url",  "id": "cta_link_2",  "label": "Secondary CTA link" }
  ],
  "presets": [ { "name": "Home hero (simple)" } ]
}
{% endschema %}
