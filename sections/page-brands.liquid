<!-- ===== MANIFESTO ===== -->
<div class="pb-manifesto">
  <div class="pb-manifesto-inner">
    <p class="pb-manifesto-eyebrow" data-reveal>The Have A Nice Day Manifesto</p>
    <h2 class="pb-manifesto-quote" data-reveal>
      "We don't follow trends.<br>We <em>set the vibe.</em>"
    </h2>
    <p class="pb-manifesto-body" data-reveal>
      Since 1990, Have A Nice Day London has been the home of independent artists who refuse to compromise. Every brand in our collective was born from a genuine creative vision — not a marketing brief. This is underground culture, printed on organic cotton, worn by people who know the difference.
    </p>
    <a href="/collections/all" class="pb-manifesto-cta" data-reveal>
      Shop All Brands →
    </a>
  </div>
</div>

<script>
(function() {
  const { animate, inView } = Motion;

  // ===== HERO ENTRANCE =====
  const eyebrow = document.getElementById('pbEyebrow');
  const title = document.getElementById('pbTitle');
  const sub = document.getElementById('pbSub');
  const count = document.getElementById('pbCount');

  if (eyebrow) animate(eyebrow, { opacity: [0,1], x: [-20,0] }, { duration: 0.6, delay: 0.1, easing: 'ease-out' });
  if (title) animate(title, { opacity: [0,1], y: [50,0] }, { duration: 0.9, delay: 0.2, easing: [0.25,0.46,0.45,0.94] });
  if (sub) animate(sub, { opacity: [0,1], y: [20,0] }, { duration: 0.7, delay: 0.45, easing: 'ease-out' });
  if (count) animate(count, { opacity: [0,1], y: [20,0] }, { duration: 0.7, delay: 0.6, easing: 'ease-out' });

  // ===== INTRO REVEALS =====
  const revealLeft = document.querySelector('[data-reveal-left]');
  const revealRight = document.querySelector('[data-reveal-right]');
  if (revealLeft) {
    inView(revealLeft, function() {
      animate(revealLeft, { opacity: [0,1], x: [-40,0] }, { duration: 0.7, easing: [0.25,0.46,0.45,0.94] });
    }, { margin: '-10% 0px' });
  }
  if (revealRight) {
    inView(revealRight, function() {
      animate(revealRight, { opacity: [0,1], x: [40,0] }, { duration: 0.7, delay: 0.1, easing: [0.25,0.46,0.45,0.94] });
    }, { margin: '-10% 0px' });
  }

  // ===== BRAND CARDS — STAGGERED =====
  const cards = document.querySelectorAll('[data-card]');
  cards.forEach(function(card, i) {
    inView(card, function() {
      animate(card,
        { opacity: [0,1], y: [40,0] },
        { duration: 0.65, delay: (i % 3) * 0.1, easing: [0.25,0.46,0.45,0.94] }
      );
    }, { margin: '-5% 0px' });
  });

  // ===== MANIFESTO REVEALS =====
  document.querySelectorAll('[data-reveal]').forEach(function(el, i) {
    inView(el, function() {
      animate(el, { opacity: [0,1], y: [24,0] }, { duration: 0.6, delay: i * 0.12, easing: 'ease-out' });
    }, { margin: '-10% 0px' });
  });

  // ===== CARD HOVER TILT =====
  cards.forEach(function(card) {
    if (card.classList.contains('featured')) return; // skip featured
    card.addEventListener('mousemove', function(e) {
      const rect = card.getBoundingClientRect();
      const x = (e.clientX - rect.left) / rect.width - 0.5;
      const y = (e.clientY - rect.top) / rect.height - 0.5;
      animate(card, { rotateX: -y * 4, rotateY: x * 4 }, { duration: 0.15, easing: 'ease-out' });
    });
    card.addEventListener('mouseleave', function() {
      animate(card, { rotateX: 0, rotateY: 0 }, { duration: 0.5, easing: [0.25,0.46,0.45,0.94] });
    });
  });

})();
</script>

